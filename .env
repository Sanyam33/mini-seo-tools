# Copy to .env and customise for your environment

# App
DEBUG=false
USER_AGENT=SEOToolsBot/1.0 (+https://yourdomain.com/bot)

# Timeouts (seconds)
HTTP_CONNECT_TIMEOUT=10.0
HTTP_READ_TIMEOUT=20.0

# Limits
MAX_TEXT_CHARS=100000
MAX_LINKS_TO_CHECK=50
MAX_SITEMAP_URLS=500
BROKEN_LINK_CONCURRENCY=10
WHOIS_API_KEY=Q5iql9A3y3A9iCACpIpAaHcwROcJnh3O


# CORS — lock down to your frontend origin in production
# ALLOWED_ORIGINS=["https://yourdomain.com","https://www.yourdomain.com"]
ALLOWED_ORIGINS=["*"]
